{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Edit(.git/**)",
      "Edit(node_modules/**)"
    ],
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(chmod *)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "rewriter",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️  Rewriter agent started — this agent CAN modify files in the target project. Ensure user has approved the changes.' >&2"
          }
        ]
      }
    ]
  }
}
