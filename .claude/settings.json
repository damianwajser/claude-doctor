{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Edit(.git/**)",
      "Edit(node_modules/**)"
    ],
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(jq *)",
      "Bash(mkdir -p *)",
      "Bash(cp * .claude-audit-backup/*)",
      "Bash(cp -r * .claude-audit-backup/*)",
      "Bash(chmod +x *)"
    ]
  },
  "sandbox": {
    "enabled": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); AGENT_TYPE=$(echo \"$INPUT\" | jq -r '.tool_input.subagent_type // empty' 2>/dev/null); if [ \"$AGENT_TYPE\" = 'rewriter' ]; then echo 'Rewriter agent requested — this agent CAN modify files in the target project. Ensure user has approved the changes.' >&2; fi; exit 0",
            "timeout": 5,
            "statusMessage": "Checking agent safety..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path' 2>/dev/null); case \"$FILE\" in *.json) jq . \"$FILE\" > /dev/null 2>&1 || echo \"WARNING: Invalid JSON in $FILE\" >&2 ;; esac; exit 0",
            "timeout": 10,
            "statusMessage": "Validating file integrity..."
          }
        ]
      }
    ]
  }
}
