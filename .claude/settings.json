{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Edit(.git/**)",
      "Edit(node_modules/**)"
    ],
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(jq *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(chmod *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); AGENT_TYPE=$(echo \"$INPUT\" | jq -r '.tool_input.subagent_type // .tool_input.prompt' 2>/dev/null); if echo \"$AGENT_TYPE\" | grep -qi 'rewriter'; then echo 'Rewriter agent requested — this agent CAN modify files in the target project. Ensure user has approved the changes.' >&2; fi; exit 0"
          }
        ]
      }
    ]
  }
}
